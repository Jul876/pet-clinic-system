<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/style.css">
<title>View Account</title>
  <style>

	
	body::before{
	content:"";
	position:fixed;
	top:0;
	left:0;
	width:100%;
	height:100%;
  background-image: url("/pet.jpg.jpg");
	background-position:center;
	background-size:cover;
	background-attachment: fixed;
	filter:blur(8px);
	z-index:-1;
	}
    
  .form-container {
   background-color: rgba(255,255,255,0.95);
      padding: 30px;
      border-radius: 12px;
      width: 600px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
      margin: 30px auto;
    }

    .content{
      display: flex;
      justify-content: center;
      align-items: flex-start;
    min-height: 70vh;
      padding: 10px;
      margin-top: 10px;
    }
    
    h1 { 
      text-align: center; 
      margin-bottom: 20px; 
      color: #222;
      margin-top: 0;
    }
    
label { 
      margin-bottom: 6px; 
      font-weight: bold; 
      color: #333; 
    }
    
    input, select { 
      padding: 12px; 
      border: 1px solid #ccc; 
      border-radius: 8px; 
      background: #f9f9f9; 
      font-size: 15px; 
      color: #555;
    }
    
    .row { 
   display: flex; 
      gap: 20px; 
      margin-bottom: 15px; 
    }
    
    .field { 
   flex: 1; 
      display: flex; 
      flex-direction: column; 
    }
    
    .button {
      width: 100%;
      margin-top: 10px;
      padding: 12px;
      background-color: #74a4d8;
      color: white;
      border: none;
      border-radius: 6px;
      cursor: pointer;
      font-size: 16px;
    }
    
    .button:hover { 
      background-color: #2c65b2; 
    }
    
    .button-container {
      display: flex;
      gap: 10px;
      margin-top: 20px;
    }
    
    .button-container .button {
      flex: 1;
      text-align: center;
      text-decoration: none;
      display: inline-block;
      line-height: normal;
    }
    
  </style>
</head>
<body>
<section class="menu">
<div class="nav">
<div class="logotitle">
    <span style="font-size: 30px; margin-bottom:28px; margin-left:35px;  cursor: pointer" onclick="openNav()">☰</span>
	<h1 style=" margin-bottom:27px;">Pet Cli<b>nic</b></h1></div>
<ul style=" margin-bottom:23px; margin-left:-15px;">
   <li><a href="/home">Home</a></li>
   <li><a href="/home#Aboutus">About us</a></li>
 </ul>
</div>
</section>

<div id="sideMenu" class="sideMenu">
    <a href="javascript:void(0)" class="closeBtn" onclick="closeNav()">×</a>
	<img src="/mm.jpg.png" class="logo">
	    <a href="/home">Home</a>
        <a href="/profile">View Profile</a>
        <a href="/pets">View All Pet</a>
        <a href="/appointment">Appointment</a>
<button class="LogOut" onclick="location.href='/logout'">Log Out</button>

    </div>
</div>

<script>
function openNav() {
    document.getElementById("sideMenu").style.width = "250px";
    document.getElementById("contentArea").style.marginLeft = "250px";
}

function closeNav() {
    document.getElementById("sideMenu").style.width = "0";
    document.getElementById("contentArea").style.marginLeft = "0";
}

function showContent(section) {
    const contentArea = document.querySelector(".contentText");
    contentArea.innerHTML = `<h2>${section}</h2><h3>Content for ${section}</h3>`;
}
</script>

<div class="content">
  <div class="form-container">
    <h1>Account Information</h1>

    <div class="row">
      <div class="field">
        <label>Name</label>
        <input type="text" value="<%= Owner.name %>" readonly>
      </div>
      <div class="field">
        <label>Phone Number</label>
        <input type="text" value="<%= Owner.phone %>" readonly>
      </div>
    </div>

    <div class="row">
      <div class="field">
        <label>Email</label>
        <input type="email" value="<%= Owner.email %>" readonly>
      </div>
      <div class="field">
        <label>Gender</label>
        <input type="text" value="<%=Owner.gender %>" readonly>
      </div>
    </div>


    <div class="button-container">
      <a href="/update" class="button">Update</a>
    </div>
  </div>
</div>

</body>
</html>  