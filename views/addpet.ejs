<script>
function openNav() {
    document.getElementById("sideMenu").style.width = "250px";
    document.getElementById("contentArea").style.marginLeft = "250px";
}

function closeNav() {
    document.getElementById("sideMenu").style.width = "0";
    document.getElementById("contentArea").style.marginLeft = "0";
}

function showContent(section) {
    const contentArea = document.querySelector(".contentText");
    contentArea.innerHTML = `<h2>${section}</h2><h3>Content for ${section}</h3>`;
}
</script>

 <div class="form-container">      
        <h1 class="title">ِAdd pet</h1>
    <form action="/pets/add" method="POST">
	
       <div class="row">
	     <div class="field">
        <label>ID:</label><br>
        <input type="text" name="id" required><br><br>
		</div>
		<div class="field">
        <label>Age:</label><br>
        <input type="number" name="age" required><br><br>
		</div>

	     <div class="field">
        <label>Name:</label><br>
        <input type="text" name="name" required><br><br>
		</div>
		</div>
		
		<div class="row">
        <div class="field">
        <label>Neutered:</label><br>
        <input type="text" name="neutered"><br><br>
		</div>

	    <div class="field">
        <label>Species:</label><br>
        <input type="text" name="species" required><br><br>
		</div>
		
		<div class="field">
        <label>Color:</label><br>
        <input type="text" name="color"><br><br>
		</div>
		</div>
		
	    <div class="row">
	    <div class="field">
        <label>Breed:</label><br>
        <input type="text" name="breed"><br><br>
		</div>
	    <div class="field">
        <label>Weight:</label><br>
        <input type="number" name="weight"><br><br>
		</div>
		
	    <div class="field">
        <label>Gender:</label><br>
        <input type="text" name="gender" required><br><br>
        </div>
		</div>

        <button type="submit">Add</button>


    </form>
</div>
