	background-attachment: fixed;
	filter:blur(8px);
	z-index:-1;
	}    
.row { 
  display:flex;
  gap:60px; 
  margin-bottom:15px;
  }
  
.field { flex:1; 
display:flex; 
flex-direction:column; 
}
  
.form-container {
      margin:0 auto;
      background-color: rgba(255, 255, 255, 0.95);
      padding: 30px; 
      border-radius: 12px; 
      width: 1000px; 
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15); 
    }
.title {
    font-size: 28px;
    margin-bottom: 20px;
    color: #1e90ff;
}
	form label {
    font-weight: bold;
    color: #1e90ff;
}

form input,
form select {
    width: 250px;
    padding: 8px;
    border: 1px solid #a4b0be;
    border-radius: 5px;
}

form button {
    padding: 10px 15px;
    margin-top: 15px;
    background: #4da3ff;
    color: white;
    border: none;
    border-radius: 5px;
}

form button:hover {
    background: #1e90ff;
}

 
 
	</style>

</head>

