<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>new Appointment</title>
        <link rel="stylesheet" href="/style.css">
		<style>

	
	body::before{
	content:"";
	position:fixed;
	top:0;
	left:0;
	width:100%;
	height:100%;
  background-image: url("/pet.jpg.jpg");
	background-position:center;
	background-size:cover;
	background-attachment: fixed;
	filter:blur(8px);
	z-index:-1;
	}

.form-container {
      margin:0 auto;
      background-color: rgba(255, 255, 255, 0.95);
      padding: 30px;
      border-radius: 12px; 
      width: 700px; 
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15); 
    }


.title {
    font-size: 28px;
    margin-bottom: 20px;
    color: #1e90ff;
}

        .pet-info {
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 20px;
        }

        .pet-info div {
            flex: 1 1 45%;
        }

        .pet-info label {
            font-weight: bold;
            color: #333;
        }

        .pet-info p {
            margin: 5px 0 15px 0;
            font-size: 16px;
            color: #555;
        }


button {
    padding: 10px 15px;
    margin-top: 15px;
    background: #4da3ff;
    color: white;
    border: none;
    border-radius: 5px;
}

button:hover {
    background: #1e90ff;
}


		</style>

</head>

<body>

<section class="menu">
<div class="nav">
<div class="logotitle">
    <span style="font-size: 30px; margin-bottom:27px;  cursor: pointer" onclick="openNav()">☰</span>
	<h1 style=" margin-bottom:27px;">Pet Cli<b>nic</b></h1></div>
<ul style=" margin-bottom:23px; margin-left:-15px;">
   <li><a href="/home">Home</a></li>
   <li><a href="/home#Aboutus">About us</a></li>
 </ul>
</div>
</section>

<div id="sideMenu" class="sideMenu">
    <a href="javascript:void(0)" class="closeBtn" onclick="closeNav()">×</a>
	<img src="/mm.jpg.png" class="logo">
	    <a href="/home">Home</a>
        <a href="/profile">View Profile</a>
        <a href="/pets">View All Pet</a>
        <a href="/appointment">Appointment</a>
<button class="LogOut" onclick="location.href='/logout'">Log Out</button>

    </div>
</div>

<script>
function openNav() {
    document.getElementById("sideMenu").style.width = "250px";
    document.getElementById("contentArea").style.marginLeft = "250px";
}

function closeNav() {
    document.getElementById("sideMenu").style.width = "0";
    document.getElementById("contentArea").style.marginLeft = "0";
}

function showContent(section) {
    const contentArea = document.querySelector(".contentText");
    contentArea.innerHTML = `<h2>${section}</h2><h3>Content for ${section}</h3>`;
}
</script>


    <div class="form-container">
        <h1 class="title">Pet Details</h1>
        <div class="pet-info">
            <div>
                <label>ID:</label>
                <p><%= pet.id %></p>
            </div>
            <div>
                <label>Name:</label>
                <p><%= pet.name %></p>
            </div>
            <div>
                <label>Age:</label>
                <p><%= pet.age %></p>
            </div>
            <div>
                <label>Gender:</label>
                <p><%= pet.gender %></p>
            </div>
            <div>
                <label>Species:</label>
                <p><%= pet.type || pet.species %></p>
            </div>
            <div>
                <label>Breed:</label>
                <p><%= pet.breed || "N/A" %></p>
            </div>

            <div>
                <label>Weight:</label>
                <p><%= pet.weight || "N/A" %></p>
            </div>
        </div>
          <button onclick="window.location='/pets'">Back to Pets</button>
    </div>

</body>
</html> 